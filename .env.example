# SendGrid (from Day 1)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@autocompany.ai

# Supabase (from Day 1)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Twilio (Day 2 - to be created)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+90XXXXXXXXX

# Vercel (Day 2 - to be created)
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_TEAM_ID=your_vercel_team_id

# Dev.to (Auto-publish CLI)
# Get your API key from: https://dev.to/settings/extensions
DEVTO_API_KEY=your_devto_api_key_here
DEVTO_API_BASE=https://dev.to/api

# GitHub (Zero-Human-Dependency Credential Pipeline)
# Create PAT at: https://github.com/settings/tokens
# Required scopes: repo (full control), workflow (read/write)
# IMPORTANT: Never commit actual token to repo!
GITHUB_TOKEN=your_github_pat_here
