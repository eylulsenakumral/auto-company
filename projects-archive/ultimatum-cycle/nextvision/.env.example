# NextVision Occupational Safety - Environment Configuration
# Copy this to .env and fill in production values

# Database
POSTGRES_PASSWORD=change_this_strong_password_123

# Redis
REDIS_PASSWORD=change_this_redis_password_456

# MinIO Object Storage
MINIO_ACCESS_KEY=nextvision_admin
MINIO_SECRET_KEY=change_this_minio_secret_789

# Application Security
JWT_SECRET=change_this_jwt_secret_please_use_strong_random_string

# RTSP Camera Configuration (First Camera)
RTSP_CAMERA_1_URL=rtsp://camera_ip:554/stream1
RTSP_CAMERA_1_NAME=Factory Floor Main
RTSP_CAMERA_1_LOCATION=production_line_a

# YOLO Model Configuration
YOLO_MODEL_VERSION=yolov8n
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
