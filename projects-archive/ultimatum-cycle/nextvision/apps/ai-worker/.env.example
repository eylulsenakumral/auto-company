# PPE Detection Worker Configuration

# Model path (absolute or relative to project root)
MODEL_PATH=./models/ppe_detector.pt

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Detection thresholds
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45

# Processing
IMAGE_SIZE=640
MAX_BATCH_SIZE=1

# Logging
LOG_LEVEL=INFO

# Performance monitoring
ENABLE_METRICS=true
