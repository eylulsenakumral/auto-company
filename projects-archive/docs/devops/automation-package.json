{
  "name": "nextvision-outreach",
  "version": "1.0.0",
  "description": "NextVision Outreach Automation - Email + VoIP for Bursa automotive suppliers",
  "main": "src/workers/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "tail": "wrangler tail",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260603.1",
    "twilio": "^5.0.0",
    "@supabase/supabase-js": "^2.39.0"
  },
  "devDependencies": {
    "wrangler": "^4.97.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
